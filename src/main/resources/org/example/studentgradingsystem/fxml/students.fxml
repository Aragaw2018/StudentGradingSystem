<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<ScrollPane fitToHeight="true" fitToWidth="true" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.studentgradingsystem.controller.StudentController"
            style="-fx-background-color: transparent;">
    <content>
        <VBox spacing="15.0" style="-fx-background-color: white;">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <Text text="Manage Students" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-fill: #2C3E50;"/>

            <HBox spacing="20" VBox.vgrow="ALWAYS">
                <!-- Input Form Section -->
                <VBox spacing="10" prefWidth="300" minWidth="300" style="-fx-background-color: #f4f4f4; -fx-padding: 15; -fx-border-color: #ddd; -fx-border-radius: 5;">

                    <Label text="Personal Information" style="-fx-font-weight: bold; -fx-font-size: 15px; -fx-text-fill: #2E86C1;"/>
                    <Separator/>

                    <Label text="Student ID:"/>
                    <TextField fx:id="idField" promptText="Enter Student ID" prefHeight="35"/>

                    <Label text="First Name:"/>
                    <TextField fx:id="firstNameField" promptText="Enter First Name" prefHeight="35"/>

                    <Label text="Last Name:"/>
                    <TextField fx:id="lastNameField" promptText="Enter Last Name" prefHeight="35"/>

                    <Label text="Email Address:"/>
                    <TextField fx:id="emailField" promptText="example@mail.com" prefHeight="35"/>

                    <Label text="Gender:"/>
                    <ComboBox fx:id="genderComboBox" promptText="Select Gender" prefWidth="270" prefHeight="35"/>

                    <Region prefHeight="10"/>
                    <Label text="Login Credentials" style="-fx-font-weight: bold; -fx-font-size: 15px; -fx-text-fill: #2E86C1;"/>
                    <Separator/>

                    <Label text="Username:"/>
                    <TextField fx:id="usernameField" promptText="Create username" prefHeight="35"/>

                    <Label text="Password:"/>
                    <PasswordField fx:id="passwordField" promptText="Create password" prefHeight="35"/>

                    <HBox spacing="8" alignment="CENTER">
                        <padding>
                            <Insets top="10"/>
                        </padding>
                        <Button text="Add" onAction="#handleAddStudent" prefWidth="65" style="-fx-background-color: #27AE60; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
                        <Button text="Update" onAction="#handleUpdateStudent" prefWidth="65" style="-fx-background-color: #2980B9; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
                        <Button text="Delete" onAction="#handleDeleteStudent" prefWidth="65" style="-fx-background-color: #C0392B; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
                        <Button text="Clear" onAction="#clearFields" prefWidth="65" style="-fx-background-color: #7F8C8D; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>

                <!-- Table Section -->
                <TableView fx:id="studentTable" HBox.hgrow="ALWAYS" onMouseClicked="#handleTableClick" style="-fx-focus-color: transparent;">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="100"/>
                        <TableColumn fx:id="colFirstName" text="First Name" prefWidth="120"/>
                        <TableColumn fx:id="colLastName" text="Last Name" prefWidth="120"/>
                        <TableColumn fx:id="colEmail" text="Email" prefWidth="180"/>
                        <TableColumn fx:id="colGender" text="Gender" prefWidth="80"/>
                    </columns>
                </TableView>
            </HBox>
        </VBox>
    </content>
</ScrollPane>