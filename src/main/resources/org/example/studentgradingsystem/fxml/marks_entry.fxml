<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.studentgradingsystem.controller.MarksController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Text text="Student Grade Management" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

    <HBox spacing="20">
        <!-- Input Form Section -->
        <VBox spacing="10" prefWidth="300" style="-fx-background-color: #f9f9f9; -fx-padding: 15; -fx-border-color: #ddd; -fx-border-radius: 5;">
            <Label text="Select Subject:" style="-fx-font-weight: bold;"/>
            <ComboBox fx:id="subjectComboBox" promptText="Choose Subject" prefWidth="270"/>

            <Label text="Select Student:" style="-fx-font-weight: bold;"/>
            <ComboBox fx:id="studentComboBox" promptText="Choose Student" prefWidth="270"/>

            <Label text="Enter Marks (0-100):" style="-fx-font-weight: bold;"/>
            <TextField fx:id="marksField" promptText="e.g. 85.5"/>

            <Separator prefHeight="10"/>

            <GridPane hgap="10" vgap="10">
                <Button text="Add" onAction="#handleSubmitMarks" prefWidth="130"
                        style="-fx-background-color: #27AE60; -fx-text-fill: white; -fx-font-weight: bold;" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <Button text="Update" onAction="#handleUpdateMarks" prefWidth="130"
                        style="-fx-background-color: #2980B9; -fx-text-fill: white; -fx-font-weight: bold;" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                <Button text="Delete" onAction="#handleDeleteMarks" prefWidth="130"
                        style="-fx-background-color: #C0392B; -fx-text-fill: white; -fx-font-weight: bold;" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <Button text="Clear" onAction="#clearFields" prefWidth="130"
                        style="-fx-background-color: #7F8C8D; -fx-text-fill: white; -fx-font-weight: bold;" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
            </GridPane>
        </VBox>

        <!-- Table Section -->
        <TableView fx:id="resultTable" HBox.hgrow="ALWAYS" onMouseClicked="#handleTableClick">
            <columns>
                <TableColumn fx:id="colStudent" text="Student Name" prefWidth="180"/>
                <TableColumn fx:id="colSubject" text="Subject" prefWidth="140"/>
                <TableColumn fx:id="colMarks" text="Marks" prefWidth="80"/>
                <TableColumn fx:id="colGrade" text="Grade" prefWidth="70"/>
                <TableColumn fx:id="colStatus" text="Status" prefWidth="90"/>
            </columns>
        </TableView>
    </HBox>
</VBox>