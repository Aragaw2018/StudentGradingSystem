<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<BorderPane fx:id="mainBoundary" prefHeight="700.0" prefWidth="1100.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.studentgradingsystem.controller.AdminDashboardController">

    <!-- Sidebar Menu -->
    <left>
        <VBox spacing="15.0" style="-fx-background-color: #2C3E50;" prefWidth="230.0">
            <padding>
                <Insets top="30.0" left="15.0" right="15.0" bottom="20.0"/>
            </padding>
            <Text text="ADMIN PANEL" fill="WHITE" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
            <Separator opacity="0.3"/>

            <Button text="Manage Students" onAction="#handleManageStudents" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-font-size: 15px;"/>

            <Button text="Manage Teachers" onAction="#handleManageTeachers" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-font-size: 15px;"/>

            <Button text="Manage Subjects" onAction="#handleManageSubjects" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-font-size: 15px;"/>

            <!-- Pushes the Logout button to the visible bottom of the Sidebar -->
            <Region VBox.vgrow="ALWAYS" />

            <Button text="Logout" onAction="#handleLogout" maxWidth="Infinity"
                    style="-fx-background-color: #E74C3C; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 10;"/>
        </VBox>
    </left>

    <!-- Content Area with ScrollPane to prevent hidden buttons -->
    <center>
        <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #ECF0F1;">
            <content>
                <VBox alignment="CENTER" spacing="30.0">
                    <padding>
                        <Insets top="40" bottom="40" left="20" right="20"/>
                    </padding>

                    <Text text="Welcome to System Administrator"
                          style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-fill: #2C3E50;"/>

                    <ImageView fitHeight="400.0" fitWidth="600.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <!-- Use @../images/ to point to the resources/images folder -->
                            <Image url="@./images/dashboard_img.png" />
                        </image>
                    </ImageView>

                    <Label text="Please select a management option from the sidebar menu to begin."
                           style="-fx-font-size: 18px; -fx-fill: #7F8C8D; -fx-font-style: italic;" wrapText="true" alignment="CENTER"/>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>