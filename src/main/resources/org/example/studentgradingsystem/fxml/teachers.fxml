<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.studentgradingsystem.controller.TeacherController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Text text="Manage Teachers" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-fill: #1E8449;"/>

    <HBox spacing="20">
        <!-- Input Form Section -->
        <VBox spacing="10" prefWidth="300" style="-fx-background-color: #f4f4f4; -fx-padding: 15; -fx-border-color: #ddd; -fx-border-radius: 5;">

            <Label text="Teacher Information" style="-fx-font-weight: bold; -fx-font-size: 15px; -fx-text-fill: #1E8449;"/>
            <Separator/>

            <Label text="Full Name:"/>
            <TextField fx:id="fullNameField" promptText="Enter Full Name"/>

            <Label text="Email Address:"/>
            <TextField fx:id="emailField" promptText="example@mail.com"/>

            <Label text="Department:"/>
            <TextField fx:id="deptField" promptText="e.g. Computer Science"/>

            <Region prefHeight="10"/>
            <Label text="Login Credentials" style="-fx-font-weight: bold; -fx-font-size: 15px; -fx-text-fill: #1E8449;"/>
            <Separator/>

            <Label text="Username:"/>
            <TextField fx:id="usernameField" promptText="Create username"/>

            <Label text="Password:"/>
            <PasswordField fx:id="passwordField" promptText="Create password"/>

            <HBox spacing="8" alignment="CENTER">
                <padding>
                    <Insets top="10"/>
                </padding>
                <Button text="Add" onAction="#handleAddTeacher" prefWidth="65" style="-fx-background-color: #27AE60; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
                <Button text="Update" onAction="#handleUpdateTeacher" prefWidth="65" style="-fx-background-color: #2980B9; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
                <Button text="Delete" onAction="#handleDeleteTeacher" prefWidth="65" style="-fx-background-color: #C0392B; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
                <Button text="Clear" onAction="#clearFields" prefWidth="65" style="-fx-background-color: #7F8C8D; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
            </HBox>
        </VBox>

        <!-- Table Section -->
        <TableView fx:id="teacherTable" HBox.hgrow="ALWAYS" onMouseClicked="#handleTableClick" style="-fx-focus-color: transparent;">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                <TableColumn fx:id="colName" text="Full Name" prefWidth="180"/>
                <TableColumn fx:id="colEmail" text="Email" prefWidth="200"/>
                <TableColumn fx:id="colDept" text="Department" prefWidth="120"/>
            </columns>
        </TableView>
    </HBox>
</VBox>