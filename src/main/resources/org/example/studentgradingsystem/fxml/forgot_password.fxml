<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<VBox alignment="CENTER" spacing="20.0" prefHeight="450.0" prefWidth="400.0"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.studentgradingsystem.controller.ForgotPasswordController"
      style="-fx-background-color: white; -fx-border-color: #E74C3C; -fx-border-width: 2;">
    <padding>
        <Insets bottom="20.0" left="30.0" right="30.0" top="20.0"/>
    </padding>

    <Text text="Reset Your Password" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-fill: #E74C3C;"/>
    <Separator/>

    <!-- Verification Section -->
    <VBox fx:id="verificationBox" spacing="10">
        <Label text="Enter Username:"/>
        <TextField fx:id="userVerifyField" promptText="Your username"/>
        <Label text="Enter Registered Email:"/>
        <TextField fx:id="emailVerifyField" promptText="Your email address"/>
        <Button text="Verify Identity" onAction="#handleVerify" maxWidth="Infinity"
                style="-fx-background-color: #34495E; -fx-text-fill: white; -fx-font-weight: bold;"/>
    </VBox>

    <!-- New Password Section (Hidden by default) -->
    <VBox fx:id="resetBox" spacing="10" visible="false" managed="false">
        <Label text="Enter New Password:"/>
        <PasswordField fx:id="newPasswordField" promptText="New password"/>
        <Label text="Confirm New Password:"/>
        <PasswordField fx:id="confirmPasswordField" promptText="Confirm password"/>
        <Button text="Update Password" onAction="#handleUpdatePassword" maxWidth="Infinity"
                style="-fx-background-color: #27AE60; -fx-text-fill: white; -fx-font-weight: bold;"/>
    </VBox>

    <Button text="Back to Login" onAction="#handleBackToLogin" style="-fx-background-color: transparent; -fx-text-fill: gray; -fx-underline: true;"/>
    <Label fx:id="statusLabel" style="-fx-text-fill: #E74C3C;"/>
</VBox>